# Pantry API backend URL — used by Next.js server-side rewrites that proxy /v1/* and /health
PANTRY_API_URL=http://localhost:7721

# Pantry API backend URL exposed to the browser — used for client-side Forge generation calls
# (these bypass the rewrite proxy to avoid timeouts on long-running generations)
NEXT_PUBLIC_PANTRY_API_URL=http://localhost:7721

# Dev/prod server port
PORT=7720
